# Root env (used by both apps)

# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
RECEIVER_PUBKEY=YOUR_RECEIVER_WALLET_PUBKEY_HERE
PORT=4000
COMMITMENT=confirmed
TOKEN_MINT=<your_spl_token_mint_address>  # required: any SPL token mint on Solana

# Web App
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
PAYER_KEYPAIR_JSON=[0,0,0,...]  # JSON array of your payer keypair secret key (64 bytes)

# Azure OpenAI (for AI endpoint)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
