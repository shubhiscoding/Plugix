# Root env (used by both apps)

# Monad Configuration
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
RECEIVER_ADDRESS=0xYOUR_RECEIVER_WALLET_ADDRESS_HERE
PORT=4000
TOKEN_ADDRESS=0xf817257fed379853cDe0fa4F97AB987181B1E5Ea  # USDC token address on Monad

# Web App
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
PAYER_PRIVATE_KEY=0xYOUR_PAYER_PRIVATE_KEY_HERE  # EVM payer wallet private key

# Azure OpenAI (for AI endpoint)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview
